# Serper.dev — used for search & research (official site lookup, contact info, competitors)
# Get a key at https://serper.dev
SERPER_API_KEY="YOUR_SERPER_API_KEY_HERE"

# OpenRouter — used for all AI reasoning/insight generation
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY="YOUR_OPENROUTER_API_KEY_HERE"

# Public URL of your deployment (used as the HTTP-Referer header for OpenRouter, optional)
APP_URL=http://localhost:3000

# Discord Bot Token and Channel ID are NOT set here — they are entered by the user
# at runtime in the app's "Discord Integration" settings panel (per the assignment spec),
# so no server-side env vars are required for that bonus feature.
